{
  "name": "@apiquest/plugin-importer-ui",
  "version": "0.1.0",
  "description": "Importer UI Plugin for ApiQuest Desktop (Postman, Insomnia, OpenAPI)",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "apiquest",
    "plugin",
    "importer",
    "desktop",
    "ui",
    "postman",
    "insomnia",
    "openapi"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build && vite build --config vite.config.host-bundle.ts && tsc --emitDeclarationOnly",
    "build:renderer": "vite build",
    "build:host": "vite build --config vite.config.host-bundle.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "vite build --watch"
  },
  "apiquest": {
    "type": "importer-ui",
    "runtime": [
      "desktop"
    ],
    "hostBundle": "dist/host-bundle.cjs",
    "capabilities": {
      "provides": {
        "importFormats": [
          "postman-v2.1",
          "insomnia-json",
          "openapi-3.0",
          "openapi-3.1"
        ]
      }
    }
  },
  "peerDependencies": {
    "@apiquest/plugin-ui-types": "workspace:*",
    "@apiquest/types": "^1.1.0",
    "@radix-ui/themes": "^3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@apiquest/plugin-ui-types": "workspace:*",
    "@apiquest/types": "^1.1.0",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
